# Stock Prediction API Environment Configuration

# Server
PORT=8000
ENVIRONMENT=production

# Sharekhan API
SHAREKHAN_CLIENT_ID=your_client_id_here
SHAREKHAN_API_KEY=your_api_key_here
SHAREKHAN_SECRET_KEY=your_secret_key_here

# NewsAPI
NEWSAPI_KEY=your_newsapi_key_here

# Claude API (for sentiment analysis)
CLAUDE_API_KEY=sk-ant-xxxxx

# Database (if needed later)
DATABASE_URL=postgresql://user:password@localhost:5432/stock_prediction

# CORS
CORS_ORIGINS=["*"]

# Logging
LOG_LEVEL=INFO
